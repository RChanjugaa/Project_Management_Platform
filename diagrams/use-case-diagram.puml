@startuml
left to right direction
actor Administrator
actor "Project Manager" as ProjectManager
actor "Team Member" as TeamMember

rectangle "Project and Team Task Management Platform" {
  usecase "Login" as UCLogin
  usecase "Logout" as UCLogout
  usecase "View Profile" as UCProfile
  usecase "Manage Users" as UCUsers
  usecase "Assign Roles" as UCRoles
  usecase "Manage System Access" as UCAccess
  usecase "Create Project" as UCCreateProject
  usecase "Assign Team Members" as UCAssignMembers
  usecase "Create Task" as UCCreateTask
  usecase "Assign Task" as UCAssignTask
  usecase "View Assigned Projects" as UCViewProjects
  usecase "View Assigned Tasks" as UCViewTasks
  usecase "Update Task Progress" as UCUpdateProgress
}

Administrator --> UCLogin
Administrator --> UCLogout
Administrator --> UCProfile
Administrator --> UCUsers
Administrator --> UCRoles
Administrator --> UCAccess

ProjectManager --> UCLogin
ProjectManager --> UCLogout
ProjectManager --> UCProfile
ProjectManager --> UCCreateProject
ProjectManager --> UCAssignMembers
ProjectManager --> UCCreateTask
ProjectManager --> UCAssignTask

TeamMember --> UCLogin
TeamMember --> UCLogout
TeamMember --> UCProfile
TeamMember --> UCViewProjects
TeamMember --> UCViewTasks
TeamMember --> UCUpdateProgress
@enduml

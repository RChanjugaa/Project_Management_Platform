{
  "info": {
    "name": "Project Team Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"replace-with-development-password\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "Current User",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/logout"
      }
    },
    {
      "name": "Admin Dashboard",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/dashboard/admin"
      }
    },
    {
      "name": "Manager Dashboard",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/dashboard/manager"
      }
    },
    {
      "name": "Member Dashboard",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/dashboard/member"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
    }
  ]
}

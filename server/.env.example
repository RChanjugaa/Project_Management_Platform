NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/project_team_management?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h

SEED_ADMIN_NAME=Development Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-development-password
SEED_ADMIN2_NAME=Second Development Admin
SEED_ADMIN2_EMAIL=admin2@example.com
SEED_ADMIN2_PASSWORD=replace-with-development-password
SEED_MANAGER_NAME=Development Manager
SEED_MANAGER_EMAIL=manager@example.com
SEED_MANAGER_PASSWORD=replace-with-development-password
SEED_MEMBER_NAME=Development Member
SEED_MEMBER_EMAIL=member@example.com
SEED_MEMBER_PASSWORD=replace-with-development-password
